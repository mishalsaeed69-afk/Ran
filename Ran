<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RUN | متجر الشراريب</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: system-ui, -apple-system, sans-serif;
}

body{
    background:#ffffff;
    color:#111;
}

/* النافبار */
.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 8%;
    border-bottom:1px solid #eee;
}

.logo{
    font-size:28px;
    font-weight:800;
    letter-spacing:2px;
}

.nav-links a{
    text-decoration:none;
    color:#111;
    margin-right:25px;
    font-weight:500;
    transition:.3s;
}

.nav-links a:hover{
    opacity:.6;
}

/* الهيرو */
.hero{
    text-align:center;
    padding:80px 20px;
}

.hero h1{
    font-size:48px;
    margin-bottom:15px;
}

.hero p{
    color:#666;
    margin-bottom:25px;
}

.btn{
    display:inline-block;
    background:#111;
    color:#fff;
    padding:12px 30px;
    text-decoration:none;
    border-radius:6px;
    transition:.3s;
}

.btn:hover{
    background:#333;
}

/* المنتجات */
.products{
    padding:60px 8%;
}

.section-title{
    font-size:28px;
    margin-bottom:30px;
    text-align:center;
}

.products-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(220px,1fr));
    gap:25px;
}

.product-card{
    border:1px solid #eee;
    border-radius:12px;
    padding:15px;
    transition:.3s;
    background:#fff;
}

.product-card:hover{
    transform:translateY(-5px);
    box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

/* مكان الصورة */
.product-img{
    width:100%;
    height:220px;
    background:#f3f3f3;
    border-radius:8px;
    margin-bottom:12px;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#999;
    font-size:14px;
}

.product-title{
    font-weight:600;
    margin-bottom:6px;
}

.price{
    color:#111;
    font-weight:700;
}

/* الفوتر */
.footer{
    margin-top:60px;
    padding:30px;
    text-align:center;
    border-top:1px solid #eee;
    color:#666;
}

/* موبايل */
@media (max-width:600px){
    .hero h1{
        font-size:34px;
    }
}
</style>
</head>

<body>

<!-- النافبار -->
<div class="navbar">
    <div class="logo">RUN</div>
    <div class="nav-links">
        <a href="#">الرئيسية</a>
        <a href="#">المتجر</a>
        <a href="#">تواصل</a>
    </div>
</div>

<!-- الهيرو -->
<section class="hero">
    <h1>شراريب RUN</h1>
    <p>راحة يومك تبدأ من قدمك</p>
    <a href="#" class="btn">تسوق الآن</a>
</section>

<!-- المنتجات -->
<section class="products">
    <h2 class="section-title">المنتجات</h2>

    <div class="products-grid">

        <div class="product-card">
            <div class="product-img">ضع الصورة هنا</div>
            <div class="product-title">شراب كلاسيك</div>
            <div class="price">25 ر.س</div>
        </div>

        <div class="product-card">
            <div class="product-img">ضع الصورة هنا</div>
            <div class="product-title">شراب رياضي</div>
            <div class="price">30 ر.س</div>
        </div>

        <div class="product-card">
            <div class="product-img">ضع الصورة هنا</div>
            <div class="product-title">شراب قطني فاخر</div>
            <div class="price">35 ر.س</div>
        </div>

    </div>
</section>

<!-- الفوتر -->
<div class="footer">
    © 2026 RUN - جميع الحقوق محفوظة
</div>

</body>
</html>
